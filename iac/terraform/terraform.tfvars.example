# terraform.tfvars.example
#
# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — never commit it (contains secrets).
#
# HOW TFVARS WORKS:
# Terraform automatically loads terraform.tfvars at plan/apply time.
# Each key here must match a variable declared in variables.tf.

# ─── PROXMOX CONNECTION ───────────────────────────────────────────────────────

# Full URL to the Proxmox API. Always ends with /api2/json.
proxmox_endpoint = "https://192.168.1.10:8006/api2/json"

# API token in the format: <user>@<realm>!<token-name>=<uuid>
# Create it in Proxmox UI → Datacenter → Permissions → API Tokens.
proxmox_api_token = "terraform@pve!tf-token=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Skip TLS certificate verification — set true for self-signed certificates.
proxmox_insecure = true

# ─── PROXMOX NODE ─────────────────────────────────────────────────────────────

# Name of the Proxmox node where containers will be created.
proxmox_node = "pve"

# ─── ACCESS ───────────────────────────────────────────────────────────────────

# SSH public key injected into every container for root access.
# Paste the output of: cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI... user@host"
